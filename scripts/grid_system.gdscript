# Grid System
# Manages the tile-based grid for the game world
# Uploaded by: Kimi

extends Node2D

class_name GridSystem

var grid_width = 100
var grid_height = 100
var tile_size = 32

func _ready():
	pass

func get_cell(x: int, y: int):
	if x >= 0 and x < grid_width and y >= 0 and y < grid_height:
		return {"x": x, "y": y}
	return null

func is_walkable(x: int, y: int) -> bool:
	var cell = get_cell(x, y)
	return cell != null
